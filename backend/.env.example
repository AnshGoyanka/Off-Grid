# Backend server
PORT=3000
NODE_ENV=development

# Algorand endpoints (Algonode defaults work without API keys)
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_INDEXER_TOKEN=
ALGORAND_NETWORK=Algorand TestNet

# Settlement wallet (required for backend-signed settlement mode)
# Fund this account from testnet faucet.
ALGORAND_SETTLER_MNEMONIC=
ALGORAND_DEFAULT_FEE=1000

# Optional backend faucet wallet (falls back to settler mnemonic if unset)
ALGORAND_FAUCET_MNEMONIC=
ALGORAND_FAUCET_AMOUNT=1000000
ALGORAND_FAUCET_URL=https://bank.testnet.algorand.network/

# CORS
CORS_ORIGINS=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=200
RATE_LIMIT_MAX_FAUCET=5
